# URL del backend TINFT raggiungibile DAL TELEFONO.
# In sviluppo usa l'IP LAN della tua macchina (NON localhost: dal telefono
# "localhost" ├© il telefono stesso). Scoprilo con `ipconfig`/`ifconfig`/`ip addr`.
#
#   API_BASE=http://192.168.1.50:3001
#
# In produzione punta all'URL deployato (https://...).
API_BASE=http://192.168.1.50:3001
