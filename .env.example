# --- Catena L2: Base ---
BASE_SEPOLIA_RPC_URL=
BASE_MAINNET_RPC_URL=

# --- Deploy contratti ---
DEPLOYER_PRIVATE_KEY=
TINFT_PAYEE=               # wallet TINFT (0,5% royalty) — M2
ORGANIZER_PAYEE=          # wallet organizzatore (0,5% royalty) — M2, deve differire da TINFT_PAYEE
BASESCAN_API_KEY=          # verifica contratti su Basescan

# --- (milestone successive) ---
# Pagamenti
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CHECKOUT_SUCCESS_URL=     # opz. default http://localhost:8080/checkout/ok
CHECKOUT_CANCEL_URL=      # opz. default http://localhost:8080/checkout/ko
# Custodia / account abstraction
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
PIMLICO_API_KEY=
# Identità SPID
SPID_OIDC_ISSUER=
SPID_OIDC_CLIENT_ID=
SPID_OIDC_CLIENT_SECRET=
# Backend → on-chain (viem): se TUTTE e tre presenti, l'API usa il mint REALE su
# TinftTicket (acquisto primario/ordini + webhook pagamenti); altrimenti FakeChain.
# Flusso on-chain reale (Base Sepolia):
#   1) Deploy:  forge script contracts/script/Deploy.s.sol \
#                 --rpc-url $BASE_SEPOLIA_RPC_URL --private-key $DEPLOYER_PRIVATE_KEY --broadcast
#      (richiede TINFT_PAYEE/ORGANIZER_PAYEE; annota l'indirizzo TinftTicket dai log)
#   2) Backend: CHAIN_RPC_URL=$BASE_SEPOLIA_RPC_URL
#               CHAIN_PRIVATE_KEY=$DEPLOYER_PRIVATE_KEY   (deve essere l'owner: mint è onlyOwner)
#               TICKET_ADDRESS=<indirizzo TinftTicket del passo 1>
# (Locale: stesso flusso con anvil — RPC http://127.0.0.1:8545 e una sua chiave finanziata.)
CHAIN_RPC_URL=
CHAIN_PRIVATE_KEY=
TICKET_ADDRESS=
# Database
DATABASE_URL=
REDIS_URL=
